<?xml version="1.0"?>
<ruleset name="Chess Project">
    <description>PHP Code Sniffer rules for Chess project</description>
    
    <!-- Paths to check -->
    <file>../../src</file>
    <exclude-pattern>*/../../vendor/*</exclude-pattern>
    
    <!-- PSR-12 Standard -->
    <rule ref="PSR12"/>
    
    <!-- Slevomat Coding Standard -->
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <properties>
            <property name="searchAnnotations" value="true"/>
        </properties>
    </rule>
</ruleset>
